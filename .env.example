# ─── Database ──────────────────────────────────────────────────────────
# PostgreSQL connection string. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local dev (matches docker-compose.yml):
DATABASE_URL="postgresql://racksmith:racksmith@localhost:5432/racksmith?schema=public"

# ─── Better Auth ───────────────────────────────────────────────────────
# Generate a fresh 32-byte secret for every deployment:
#   openssl rand -hex 32
# Rotate immediately if leaked — all existing sessions become invalid.
BETTER_AUTH_SECRET=""

# Must match the URL users reach RackSmith at (no trailing slash).
# Used for session cookies, password reset + verification links, OAuth redirects.
# Dev:  http://localhost:3000
# Prod: https://racksmith.yourcompany.com
BETTER_AUTH_URL="http://localhost:3000"

# Optional client-side override — set when the browser-facing URL differs from
# the server-side BETTER_AUTH_URL (e.g. behind a CDN or reverse proxy that
# rewrites the host). Read by src/lib/auth-client.ts. Most deployments leave
# this empty.
NEXT_PUBLIC_BETTER_AUTH_URL=""

# ─── OAuth (optional) ──────────────────────────────────────────────────
# The login/signup pages only show these buttons when both ID + secret are set.
# Leave empty to use email/password only.
#
# GitHub:  https://github.com/settings/developers
#   Callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google:  https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email delivery (optional) ─────────────────────────────────────────
# Without RESEND_API_KEY, all outbound emails are printed to stderr instead of
# sent (dev-mode logger). That's fine for local dev and self-hosters who don't
# want real email. Set this in production to send via Resend.
#
# Get a key:  https://resend.com/api-keys
RESEND_API_KEY=""

# Sender address shown in outgoing mail. Must be a Resend-verified domain in
# production. Defaults to "RackSmith <noreply@racksmith.local>" if unset.
# RACKSMITH_EMAIL_FROM="RackSmith <noreply@yourdomain.com>"

# ─── Stripe billing (Phase 13) ─────────────────────────────────────────
# Hosted-only billing — paid tiers run on the official RackSmith service.
# Dev uses test-mode keys (pk_test_*, sk_test_*, whsec_*); prizmo uses
# live-mode keys (pk_live_*, sk_live_*, whsec_*). Mismatched keys silently
# fail — verify the prefixes match the environment before deploying.
#
# Dashboard: https://dashboard.stripe.com/apikeys (and ../webhooks)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# Webhook signing secret (one per endpoint). Stripe Dashboard → Developers
# → Webhooks → click endpoint → "Signing secret" → reveal. Format: whsec_*.
# Used to verify HMAC signatures on /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (one per tier × billing cycle). Create the four prices
# under "RackSmith Pro" + "RackSmith Business" products in Stripe Dashboard
# → Products. Test-mode and live-mode have different IDs — keep them in
# their respective .env files.
#   Pro:      $9/mo or $90/yr
#   Business: $29/seat/mo or $290/seat/yr (per-unit pricing, quantity = members)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_BUSINESS_ANNUAL=""
